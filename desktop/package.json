{
  "name": "sentiment-monitor-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for Sentiment Monitor",
  "author": "realguoshuai",
  "main": "main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "app": "electron .",
    "build:backend": "node scripts/build-backend.cjs",
    "build:frontend": "npm --prefix ../frontend run build",
    "generate:icon": "powershell -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "prepare:package": "node scripts/prepare-package.cjs",
    "pack": "npm run prepare:package && electron-builder --dir",
    "dist": "npm run prepare:package && electron-builder --win nsis portable",
    "check": "node --check main.cjs && node --check preload.cjs && node --check scripts/dev.cjs && node --check scripts/build-backend.cjs && node --check scripts/prepare-package.cjs"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.realguoshuai.sentiment-monitor",
    "productName": "Sentiment Monitor",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json",
      "frontend-dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "../backend/dist/SentimentMonitor-runtime",
        "to": "backend"
      },
      {
        "from": "../backend/db.sqlite3",
        "to": "backend/db.sqlite3"
      },
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "SentimentMonitor-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "SentimentMonitor-Portable-${version}-${arch}.${ext}"
    }
  }
}
